## ─────────────────────────────────────────────────────────────────────────────
## STORY LEVEL BASE SCENE
## ─────────────────────────────────────────────────────────────────────────────
## HOW TO USE:
## 1. Duplicate this scene (Ctrl+Shift+D in the FileSystem dock) for each level.
## 2. On the StoryLevelController node, set nav_region and visual_tilemap.
## 3. Paint your ship on the TileMapLayer (source 0 = walls, source 1 = floors).
## 4. Add RoomMarker children (Scripts/StoryMode/room_marker.gd) and set
##    room_rect_tiles + room_type for each room.  Mark outer rooms is_outer_room=true.
## 5. Instance door.tscn / escape_pod.tscn children and place them in the scene.
## 6. Optionally add NpcSpawnPoint children for precise NPC placement.
## 7. Tweak gameplay export variables on StoryLevelController in the Inspector.
## ─────────────────────────────────────────────────────────────────────────────

[node name="StoryLevel" type="Node2D"]
process_mode = 1
script = ExtResource("1_slc")
nav_region = NodePath("NavigationRegion2D")
visual_tilemap = NodePath("TileMapLayer")
floor_tile_source_id = 1
wall_tile_source_id = 0
enemy_chase_speed = 70.0
enemy_spawn_delay = 4.0
enemy_respawn_interval = 20.0
max_enemies_alive = 2
npc_speed_modifier = 1.0
escalation_interval = 30.0
escalation_step = 0.12
escape_pod_capacity_override = 0
npc_scene = ExtResource("6_npc")
npc_classes = Array[ExtResource("res://Scripts/Resources/npc_class.gd")]([ExtResource("9_thief"), ExtResource("10_intern"), ExtResource("11_captain"), ExtResource("12_janitor"), ExtResource("13_engineer"), ExtResource("14_crew")])
npc_count = 10

