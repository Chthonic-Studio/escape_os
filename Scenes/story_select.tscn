[gd_scene format=3 uid="uid://bstory_select1"]

[ext_resource type="Script" uid="uid://bstory_select2" path="res://UI/story_select.gd" id="1_ss"]
[ext_resource type="FontFile" uid="uid://bpeaberry1" path="res://Assets/PeaberryMono.ttf" id="2_font"]

[node name="StorySelect" type="CanvasLayer"]
layer = 100
script = ExtResource("1_ss")

[node name="Background" type="ColorRect" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.02, 0.02, 0.05, 0.96)

[node name="HBox" type="HBoxContainer" parent="Background"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 0

[node name="LeftPanel" type="VBoxContainer" parent="Background/HBox"]
custom_minimum_size = Vector2(320, 0)
layout_mode = 2
size_flags_vertical = 3
theme_override_constants/separation = 12

[node name="MarginContainer" type="MarginContainer" parent="Background/HBox/LeftPanel"]
layout_mode = 2
size_flags_vertical = 3
theme_override_constants/margin_left = 30
theme_override_constants/margin_top = 30
theme_override_constants/margin_right = 20
theme_override_constants/margin_bottom = 20

[node name="VBox" type="VBoxContainer" parent="Background/HBox/LeftPanel/MarginContainer"]
layout_mode = 2
size_flags_vertical = 3
theme_override_constants/separation = 16

[node name="TitleLabel" type="Label" parent="Background/HBox/LeftPanel/MarginContainer/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 0.2, 0.2, 1)
theme_override_fonts/font = ExtResource("2_font")
theme_override_font_sizes/font_size = 13
text = "═══ SELECT STORY ═══"
horizontal_alignment = 0

[node name="SubtitleLabel" type="Label" parent="Background/HBox/LeftPanel/MarginContainer/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.4, 0.4, 0.4, 1)
theme_override_fonts/font = ExtResource("2_font")
theme_override_font_sizes/font_size = 9
text = "Hover a story to read its description."

[node name="Separator1" type="HSeparator" parent="Background/HBox/LeftPanel/MarginContainer/VBox"]
layout_mode = 2

[node name="ScrollContainer" type="ScrollContainer" parent="Background/HBox/LeftPanel/MarginContainer/VBox"]
layout_mode = 2
size_flags_vertical = 3

[node name="StoryList" type="VBoxContainer" parent="Background/HBox/LeftPanel/MarginContainer/VBox/ScrollContainer"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 8

[node name="Separator2" type="HSeparator" parent="Background/HBox/LeftPanel/MarginContainer/VBox"]
layout_mode = 2

[node name="BackButton" type="Button" parent="Background/HBox/LeftPanel/MarginContainer/VBox"]
custom_minimum_size = Vector2(120, 36)
layout_mode = 2
theme_override_fonts/font = ExtResource("2_font")
theme_override_font_sizes/font_size = 10
text = "< BACK"

[node name="RightPanel" type="PanelContainer" parent="Background/HBox"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3

[node name="VBox" type="VBoxContainer" parent="Background/HBox/RightPanel"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="MarginContainer" type="MarginContainer" parent="Background/HBox/RightPanel/VBox"]
layout_mode = 2
theme_override_constants/margin_left = 24
theme_override_constants/margin_top = 24
theme_override_constants/margin_right = 24
theme_override_constants/margin_bottom = 12

[node name="InnerVBox" type="VBoxContainer" parent="Background/HBox/RightPanel/VBox/MarginContainer"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="DescTitle" type="Label" parent="Background/HBox/RightPanel/VBox/MarginContainer/InnerVBox"]
