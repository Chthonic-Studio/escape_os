[resource]
script = ExtResource("1_sd")
story_name = "Chapter I: First Contact"
story_description = "Deep in corporate-controlled space, a routine resupply mission goes catastrophically wrong. Hostile organisms have breached containment. You are the ship's emergency AI — your directive: maximise shareholder value through personnel retention.\n\nThis is the first chapter of the Escape OS story campaign."
story_subtitle = "A routine mission. An extraordinary catastrophe."
story_id = &"chapter_1"
levels = Array[ExtResource("res://Scripts/Resources/story_level_data.gd")]([ExtResource("2_lvl1")])
